<style>
  .landing-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    /* Mobile-first padding */
    padding: 40px 20px 60px;
    text-align: center;
    color: var(--kp-on-surface);
  }

  @media (min-width: 768px) {
    .landing-wrapper { padding: 80px 32px; }
  }
  
  .landing-hero {
    margin-bottom: 48px;
    animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @media (min-width: 768px) {
    .landing-hero { margin-bottom: 80px; }
  }
  
  .landing-title {
    /* Fluid type: 36px mobile → 56px desktop */
    font-size: clamp(32px, 6vw + 16px, 56px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--kp-on-surface);
    letter-spacing: -0.5px;
  }

  @media (min-width: 640px) {
    .landing-title { letter-spacing: -1px; margin-bottom: 24px; }
  }
  
  .landing-title span {
    color: var(--kp-primary);
  }
  
  .landing-subtitle {
    font-size: clamp(16px, 2vw + 10px, 20px);
    color: var(--kp-on-surface-variant);
    max-width: 600px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  
  .landing-cta {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  
  .btn-hero {
    /* 44px min-height already from btn base */
    padding: 12px 24px;
    font-size: 16px;
    font-weight: 600;
    min-width: 160px;
  }

  @media (min-width: 480px) {
    .btn-hero { padding: 14px 28px; font-size: 17px; }
  }

  @media (min-width: 640px) {
    .btn-hero { padding: 16px 32px; font-size: 18px; }
  }

  /* Full-width CTAs on very small screens */
  @media (max-width: 360px) {
    .landing-cta { flex-direction: column; align-items: center; }
    .btn-hero { width: 100%; }
  }
  
  .features-grid {
    display: grid;
    /* 1 column on mobile, 2 on tablet, 3 on desktop */
    grid-template-columns: 1fr;
    gap: 20px;
    text-align: left;
  }

  @media (min-width: 600px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }

  @media (min-width: 960px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); gap: 32px; }
  }
  
  .feature-card {
    background: var(--kp-surface);
    padding: 24px;
    border-radius: var(--kp-radius-xl);
    border: 1px solid var(--kp-outline-variant);
    box-shadow: var(--kp-shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media (min-width: 768px) {
    .feature-card { padding: 32px; }
  }
  
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--kp-shadow-lg);
  }
  
  .feature-icon {
    width: 48px;
    height: 48px;
    background: var(--kp-primary-container);
    color: var(--kp-primary);
    border-radius: var(--kp-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }
  
  .feature-icon .material-symbols-outlined {
    font-size: 26px;
  }
  
  .feature-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
  }

  @media (min-width: 768px) {
    .feature-title { font-size: 20px; }
  }
  
  .feature-desc {
    color: var(--kp-on-surface-variant);
    line-height: 1.6;
    font-size: 15px;
  }
  
  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="landing-wrapper">
  <div class="landing-hero">
    <h1 class="landing-title">Gestiona proyectos con <span>KanbanPro</span></h1>
    <p class="landing-subtitle">
      Optimiza tus flujos de trabajo, visualiza el progreso y colabora en tiempo real con la herramienta Kanban diseñada para la excelencia operativa.
    </p>
    <div class="landing-cta">
      <a href="/register" class="btn btn-primary btn-hero">Comenzar Gratis</a>
      <a href="/dashboard" class="btn btn-secondary btn-hero">Ver Demo</a>
    </div>
  </div>

  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">
        <span class="material-symbols-outlined">drag_indicator</span>
      </div>
      <h3 class="feature-title">Drag & Drop Intuitivo</h3>
      <p class="feature-desc">
        Mueve tareas entre columnas fácilmente. Organiza tu trabajo visualmente para que todo el equipo sepa qué hacer y cuándo.
      </p>
    </div>
    
    <div class="feature-card">
      <div class="feature-icon">
        <span class="material-symbols-outlined">flag</span>
      </div>
      <h3 class="feature-title">Gestión de Prioridades</h3>
      <p class="feature-desc">
        Clasifica tareas por urgencia e importancia. Asegúrate de que tu equipo siempre esté enfocado en lo que aporta mayor valor.
      </p>
    </div>
    
    <div class="feature-card">
      <div class="feature-icon">
        <span class="material-symbols-outlined">group</span>
      </div>
      <h3 class="feature-title">Colaboración Eficaz</h3>
      <p class="feature-desc">
        Invita a otros miembros a tus tableros, asigna roles de visualizador, editor o administrador y mantén la sincronización total.
      </p>
    </div>
  </div>
</div>