<div class="dashboard-content">
  {{#if isDemo}}
  <div class="demo-banner">
    <span class="material-symbols-outlined">warning</span>
    <div>
      <strong>Modo Demo:</strong> Todo sucede en tu navegador. Si deseas guardar tus cambios en la nube, <a href="/register">regístrate gratis</a>.
    </div>
  </div>
  <script>window.IS_DEMO = true;</script>
  {{/if}}

  <div class="dashboard-header">
    <div class="dashboard-actions">
      <select id="selectTablero" class="kp-select" aria-label="Seleccionar tablero">
        <option value="">-- Selecciona un tablero --</option>
        {{#each data.tableros}}
          <option value="{{this.id}}">{{this.titulo}}</option>
        {{/each}}
      </select>
    </div>
    <div class="dashboard-actions">
      <button id="btnAbrirModal" class="btn btn-primary">
        <span class="material-symbols-outlined">add</span>
        Nueva Tarea
      </button>
    </div>
  </div>

  {{#each data.tableros}}
    <div class="tablero" data-tablero-id="{{this.id}}" style="display: none;">
      <div class="kanban-board kp-board-canvas">
        {{#each this.listas}}
          <div class="lista kp-kanban-col" data-id="{{this.id}}" role="region" aria-label="Lista: {{this.titulo}}">
            <div class="kp-col-header">
              <div class="kp-col-title">
                {{this.titulo}}
              </div>
              <div class="kp-col-badge">{{this.tarjetas.length}}</div>
            </div>

            <div class="tarjetas" id="lista-{{this.id}}">
              {{#each this.tarjetas}}
                <div class="tarjeta kp-task-card" data-id="{{this.id}}" data-priority="{{this.prioridad}}" tabindex="0">
                  <div class="kp-priority-badge kp-priority-{{this.prioridad}}">
                    {{this.prioridad}}
                  </div>
                  
                  <div class="kp-card-actions">
                    <button onclick="abrirModalEditar('{{this.id}}', '{{this.titulo}}', '{{this.descripcion}}', '{{this.prioridad}}')" title="Editar">
                      <span class="material-symbols-outlined" style="font-size: 16px;">edit</span>
                    </button>
                    <button onclick="eliminarTarjeta('{{this.id}}')" title="Eliminar" style="color: var(--kp-error);">
                      <span class="material-symbols-outlined" style="font-size: 16px;">delete</span>
                    </button>
                  </div>

                  <h4 class="kp-card-title mt-4">{{this.titulo}}</h4>
                  
                  {{#if this.descripcion}}
                    <p class="kp-card-desc">{{this.descripcion}}</p>
                  {{/if}}
                </div>
              {{/each}}
            </div>
          </div>
        {{/each}}
      </div>
    </div>
  {{/each}}
</div>

<!-- Modal Nueva Tarea -->
<div id="modalTarea" class="modal-overlay" role="dialog" aria-modal="true">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Nueva Tarea</h2>
      <button id="btnCerrarModal" class="close-modal">&times;</button>
    </div>

    <form method="POST" action="/nueva-tarjeta">
      <input type="hidden" id="formTableroId" name="tableroId" value="" />
      
      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 16px;">
        <div class="form-group">
          <label for="titulo" class="form-label">Título *</label>
          <input type="text" id="titulo" name="titulo" class="form-input" required placeholder="Ej: Implementar login" />
        </div>

        <div class="form-group">
          <label for="prioridad" class="form-label">Prioridad</label>
          <select id="prioridad" name="prioridad" class="form-input">
            <option value="Baja">Baja</option>
            <option value="Media" selected>Media</option>
            <option value="Alta">Alta</option>
            <option value="Urgente">Urgente</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="descripcion" class="form-label">Descripción</label>
        <textarea id="descripcion" name="descripcion" class="form-input" rows="3" placeholder="Detalles de la tarea..."></textarea>
      </div>

      <div class="form-group">
        <label for="lista" class="form-label">Lista Destino *</label>
        <select id="lista" name="lista" required class="form-input">
          <option value="todo">Por Hacer</option>
          <option value="in-progress">En Progreso</option>
          <option value="done">Completado</option>
        </select>
      </div>

      <div class="modal-actions">
        <button type="button" id="btnCancelar" class="btn btn-secondary btn-cancelar-modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Crear Tarea</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Editar Tarea -->
<div id="modalEditarTarea" class="modal-overlay" role="dialog" aria-modal="true">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Editar Tarea</h2>
      <button type="button" class="close-modal btn-cerrar-editar">&times;</button>
    </div>

    <form id="formEditarTarea">
      <input type="hidden" id="editTaskId" name="id">
      
      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 16px;">
        <div class="form-group">
          <label for="editTitulo" class="form-label">Título *</label>
          <input type="text" id="editTitulo" name="titulo" class="form-input" required />
        </div>
        <div class="form-group">
          <label for="editPrioridad" class="form-label">Prioridad</label>
          <select id="editPrioridad" name="prioridad" class="form-input">
            <option value="Baja">Baja</option>
            <option value="Media">Media</option>
            <option value="Alta">Alta</option>
            <option value="Urgente">Urgente</option>
          </select>
        </div>
      </div>
      
      <div class="form-group">
        <label for="editDescripcion" class="form-label">Descripción</label>
        <textarea id="editDescripcion" name="descripcion" class="form-input" rows="3"></textarea>
      </div>
      
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary btn-cancelar-modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="/js/kanban.js"></script>