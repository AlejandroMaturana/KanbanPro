<div class="dashboard-content">
  {{#if isDemo}}
  <div class="demo-banner">
    ⚠️ <strong>Modo Demo:</strong> Todo sucede en tu navegador. Si deseas guardar tus cambios en la nube, <a href="/register">regístrate gratis</a>.
  </div>
  <script>window.IS_DEMO = true;</script>
  {{/if}}

  <div class="dashboard-header">
    <div class="dashboard-top">
      <h1>Dashboard - KanbanPro</h1>
      <div class="tablero-controls">
        <select id="selectTablero" aria-label="Seleccionar tablero">
          <option value="">-- Selecciona un tablero --</option>
          {{#each data.tableros}}
            <option value="{{this.id}}">{{this.titulo}}</option>
          {{/each}}
        </select>
        <button id="btnNuevoTablero" class="btn-nuevo-tablero" title="Crear nuevo tablero">
          ➕ Nuevo Tablero
        </button>
      </div>
    </div>
    <button id="btnAbrirModal" aria-label="Abrir modal para nueva tarea">
      <span aria-hidden="true">+</span> Nueva Tarea
    </button>
  </div>

  {{#each data.tableros}}
    <div class="tablero" data-tablero-id="{{this.id}}">
      <h2 class="tablero-title">{{this.titulo}}</h2>

      <div class="kanban-board">
        {{#each this.listas}}
          <div class="lista" data-id="{{this.id}}" role="region" aria-label="Lista de tareas: {{this.titulo}}">
            <h3 class="lista-header">{{this.titulo}}</h3>

            <div class="tarjetas" id="lista-{{this.id}}">
              {{#each this.tarjetas}}
                <div class="tarjeta" data-id="{{this.id}}" tabindex="0" role="article" aria-label="Tarea: {{this.titulo}}">
                  <div class="tarjeta-header">
                    <h4>{{this.titulo}}</h4>
                    <div class="tarjeta-actions">
                      <button
                        onclick="abrirModalEditar('{{this.id}}', '{{this.titulo}}', '{{this.descripcion}}', '{{this.prioridad}}')"
                        class="btn-edit"
                        title="Editar tarea"
                        aria-label="Editar la tarea {{this.titulo}}"
                      >✏️</button>
                      <button
                        onclick="eliminarTarjeta('{{this.id}}')"
                        class="btn-delete"
                        title="Eliminar tarea"
                        aria-label="Eliminar la tarea {{this.titulo}}"
                      >🗑️</button>
                    </div>
                  </div>

                  <div class="prioridad-wrapper">
                    <span class="prioridad-tag prioridad-{{this.prioridad}}">
                      {{this.prioridad}}
                    </span>
                  </div>

                  {{#if this.descripcion}}
                    <p class="tarjeta-desc">{{this.descripcion}}</p>
                  {{/if}}
                </div>
              {{/each}}
            </div>
          </div>
        {{/each}}
      </div>
    </div>
  {{/each}}
</div>

<!-- Modal para añadir nueva tarjeta -->
<div id="modalTarea" class="modal-overlay" role="dialog" aria-labelledby="modal-nueva-tarea-title" aria-modal="true">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modal-nueva-tarea-title">➕ Crear Nueva Tarea</h2>
      <button id="btnCerrarModal" class="close-modal" aria-label="Cerrar modal">&times;</button>
    </div>

    <form method="POST" action="/nueva-tarjeta">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="titulo">Título *</label>
          <input
            type="text"
            id="titulo"
            name="titulo"
            class="form-control"
            required
            placeholder="Título de la tarea"
          />
        </div>

        <div class="form-group">
          <label for="prioridad">Prioridad</label>
          <select id="prioridad" name="prioridad" class="form-control">
            <option value="Baja">Baja</option>
            <option value="Media" selected>Media</option>
            <option value="Alta">Alta</option>
            <option value="Urgente">Urgente</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="descripcion">Descripción</label>
        <textarea
          id="descripcion"
          name="descripcion"
          class="form-control"
          rows="3"
          placeholder="Más detalles..."
        ></textarea>
      </div>

      <div class="form-group">
        <label for="lista">Lista Destino *</label>
        <select id="lista" name="lista" required class="form-control">
          <option value="todo">Por Hacer</option>
          <option value="in-progress">En Progreso</option>
          <option value="done">Completado</option>
        </select>
      </div>

      <div class="modal-actions">
        <button type="button" id="btnCancelar" class="btn-cancel btn-cancelar-modal" aria-label="Cancelar creación">Cancelar</button>
        <button type="submit" class="btn-primary" aria-label="Confirmar crear tarea">Crear Tarea</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal para editar tarjeta -->
<div id="modalEditarTarea" class="modal-overlay" role="dialog" aria-labelledby="modal-editar-tarea-title" aria-modal="true">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modal-editar-tarea-title">✏️ Editar Tarea</h2>
      <button type="button" class="close-modal btn-cerrar-editar" aria-label="Cerrar modal">&times;</button>
    </div>

    <form id="formEditarTarea">
      <input type="hidden" id="editTaskId" name="id">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label for="editTitulo">Título *</label>
          <input type="text" id="editTitulo" name="titulo" class="form-control" required />
        </div>
        <div class="form-group">
          <label for="editPrioridad">Prioridad</label>
          <select id="editPrioridad" name="prioridad" class="form-control">
            <option value="Baja">Baja</option>
            <option value="Media">Media</option>
            <option value="Alta">Alta</option>
            <option value="Urgente">Urgente</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="editDescripcion">Descripción</label>
        <textarea id="editDescripcion" name="descripcion" class="form-control" rows="3"></textarea>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-cancel btn-cancelar-modal" aria-label="Cancelar edición">Cancelar</button>
        <button type="submit" class="btn-primary" aria-label="Guardar cambios de la tarea">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>



<!-- Scripts para Drag & Drop y Lógica Kanban -->
<script
  src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"
></script>
<script src="/js/kanban.js"></script>