<div class="auth-card">
  <h1 class="text-center">Crear Cuenta</h1>
  <p class="text-center text-muted">
    Regístrate para comenzar a usar KanbanPro
  </p>

  <form>
    <div class="form-group">
      <label for="nombre" class="form-label">Nombre completo</label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        class="form-input"
        placeholder="Tu nombre completo"
        required
      />
    </div>

    <div class="form-group">
      <label for="email" class="form-label">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        class="form-input"
        placeholder="ejemplo@correo.com"
        required
      />
    </div>

    <div class="form-group">
      <label for="password" class="form-label">Contraseña</label>
      <div style="position: relative;">
        <input
          type="password"
          id="password"
          name="contrasena"
          class="form-input"
          placeholder="Crea una contraseña segura"
          required
        />
        <button type="button" class="toggle-password" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; font-size: 18px; color: var(--text-secondary);" aria-label="Mostrar contraseña">
           👁️
        </button>
      </div>
    </div>

    <button type="submit" class="btn-primary-large mt-4">
      Registrarse
    </button>
  </form>

  <p class="text-center mt-4 text-muted">
    ¿Ya tienes una cuenta?
    <a href="/login" class="text-primary-link">Inicia sesión aquí</a>
  </p>
</div>

<script src="/js/auth.js"></script>