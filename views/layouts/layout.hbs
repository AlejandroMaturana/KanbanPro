<html lang="es">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{#if title}}{{title}} - {{/if}}KanbanPro</title>
    <link rel="icon" href="/data/icon.ico" type="image/x-icon" />
    <meta
      name="description"
      content="KanbanPro - Sistema de gestión de tareas"
    />
    <meta name="keywords" content="Kanban, Tareas, Gestión, Productividad" />
    <meta name="AlejandroMaturana" content="KanbanPro" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
          Cantarell, sans-serif;
        background: #d9d9d9;
        min-height: 100vh;
        color: #222;
      }

      .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 12px;
      }

      header {
        background: #c6c6c6;
        padding: 10px 0;
        border-bottom: 1px solid #9a9a9a;
        margin-bottom: 12px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 20px;
        font-weight: bold;
        color: #2f2f2f;
      }

      .nav-links {
        display: flex;
        gap: 10px;
        list-style: none;
      }

      .nav-links a {
        text-decoration: none;
        color: #2a2a2a;
        padding: 4px 8px;
        border: 1px solid #a0a0a0;
        background: #e3e3e3;
      }

      .nav-links a:hover {
        background: #d3d3d3;
      }

      main {
        background: #efefef;
        padding: 16px;
        border: 1px solid #b5b5b5;
        min-height: 60vh;
      }

      footer {
        text-align: center;
        padding: 10px;
        color: #3a3a3a;
        margin-top: 12px;
      }
    </style>
  </head>

  <body>
    <header>
      <div class="container">
        <nav>
          <div class="logo">📋 KanbanPro</div>

          {{#if isAutenticado}}
            <div
              class="user-welcome"
              style="flex-grow: 1; margin-left: 20px; font-size: 14px; color: #444;"
            >
              Bienvenido,
              <strong>{{nombreUsuario}}</strong>
            </div>
          {{/if}}

          <ul class="nav-links">
            <li><a href="/">Inicio</a></li>
            {{#if isAutenticado}}
              <li><a href="/dashboard">Dashboard</a></li>
              <li><a href="/logout">Cerrar Sesión</a></li>
            {{else}}
              <li><a href="/register">Registro</a></li>
              <li><a href="/login">Iniciar Sesión</a></li>
            {{/if}}
          </ul>
        </nav>
      </div>
    </header>

    <div class="container">
      <main>
        {{{body}}}
      </main>
    </div>

    <footer
      style="margin-top: 50px; padding: 40px 0; background: #2d3748; color: #cbd5e0; border-top: 4px solid #667eea;"
    >
      <div
        class="container"
        style="display: flex; flex-direction: column; align-items: center; gap: 15px;"
      >
          &copy; 2026 KanbanPro - Otra idea de Alejandro Maturana.
        </p>
        <div style="display: flex; gap: 20px; margin-top: 10px;">
          <a
            href="/cookie-policy"
            style="color: #667eea; text-decoration: none; font-size: 13px;"
          >Términos</a>
          <a
            href="/privacy-policy"
            style="color: #667eea; text-decoration: none; font-size: 13px;"
          >Privacidad</a>
          <a
            href="mailto:neofito331@gmail.com"
            style="color: #667eea; text-decoration: none; font-size: 13px;"
          >Contacto</a>
        </div>
      </div>
    </footer>
    {{{_scripts}}}
  </body>

</html>