<html lang="es">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{#if title}}{{title}} - {{/if}}KanbanPro</title>
    <link rel="icon" href="/data/icon.ico" type="image/x-icon" />
    <meta
      name="description"
      content="KanbanPro - Sistema de gestión de tareas"
    />
    <meta name="keywords" content="Kanban, Tareas, Gestión, Productividad" />
    <meta name="AlejandroMaturana" content="KanbanPro" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/dashboard.css" />
  </head>

  <body>
    <header>
      <div class="container">
        <nav>
          <div class="logo">📋 KanbanPro</div>

          {{#if isAutenticado}}
            <div
              class="user-welcome"
              style="flex-grow: 1; margin-left: 20px; font-size: 14px; color: var(--text-secondary);"
            >
              Bienvenido,
              <strong>{{nombreUsuario}}</strong>
            </div>
          {{/if}}

          <ul class="nav-links">
            <li><a href="/">Inicio</a></li>
            {{#if isAutenticado}}
              <li><a href="/dashboard">Dashboard</a></li>
              <li><a href="/logout">Cerrar Sesión</a></li>
            {{else}}
              <li><a href="/register">Registro</a></li>
              <li><a href="/login">Iniciar Sesión</a></li>
            {{/if}}
            <li>
              <button id="theme-toggle" class="theme-toggle-btn" title="Alternar tema" aria-label="Alternar tema oscuro/claro">
                🌙
              </button>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="container">
      <main>
        {{{body}}}
      </main>
    </div>

    <footer>
      <div class="container" style="display: flex; flex-direction: column; align-items: center; gap: 15px;">
        <p>&copy; 2026 KanbanPro - Otra idea de Alejandro Maturana.</p>
        <div style="display: flex; gap: 20px; margin-top: 10px;">
          <a href="/cookie-policy">Términos</a>
          <a href="/privacy-policy">Privacidad</a>
          <a href="mailto:neofito331@gmail.com">Contacto</a>
        </div>
      </div>
    </footer>

    <!-- Toast Notification Container -->
    <div id="toast-container" class="toast-container"></div>

    <!-- Custom Confirm Modal -->
    <div id="custom-confirm" class="custom-confirm-overlay">
      <div class="custom-confirm-modal">
        <div class="custom-confirm-header" id="confirm-header">Confirmar Acción</div>
        <div class="custom-confirm-body" id="confirm-body">¿Estás seguro?</div>
        <div class="custom-confirm-actions">
          <button class="custom-confirm-btn btn-secondary" id="confirm-cancel">Cancelar</button>
          <button class="custom-confirm-btn btn-danger" id="confirm-ok">Aceptar</button>
        </div>
      </div>
    </div>

    {{{_scripts}}}
  </body>

</html>