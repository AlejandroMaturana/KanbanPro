<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{#if title}}{{title}} - {{/if}}KanbanPro</title>
  <link rel="icon" href="/data/icon.ico" type="image/x-icon" />
  <meta name="description" content="KanbanPro - Sistema de gestión de tareas" />
  
  <!-- Material Symbols for Icons -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  
  <link rel="stylesheet" href="/css/main.css" />
  
  <style>
    /* Kinetic background for auth pages */
    .kp-auth-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle at 50% 0%, var(--kp-primary-container) 0%, var(--kp-bg-body) 60%);
      padding: 24px;
    }
    
    .auth-card {
      background: var(--kp-surface);
      width: 100%;
      max-width: 440px;
      padding: 48px 40px;
      border-radius: var(--kp-radius-xl);
      box-shadow: var(--kp-shadow-xl);
      border: 1px solid var(--kp-outline-variant);
      position: relative;
      overflow: hidden;
    }
    
    /* Decorative top accent */
    .auth-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 6px;
      background: var(--kp-primary);
    }
    
    .auth-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      font-size: 28px;
      font-weight: 700;
      color: var(--kp-primary);
      margin-bottom: 32px;
      font-family: 'DM Sans', sans-serif;
    }
    
    .auth-title {
      text-align: center;
      font-size: 24px;
      margin-bottom: 8px;
      color: var(--kp-on-surface);
    }
    
    .auth-subtitle {
      text-align: center;
      color: var(--kp-on-surface-variant);
      margin-bottom: 32px;
      font-size: 15px;
    }
    
    .input-with-icon {
      position: relative;
    }
    
    .input-with-icon .material-symbols-outlined {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--kp-on-surface-muted);
    }
    
    .input-with-icon .form-input {
      padding-left: 48px;
    }
    
    .btn-auth-submit {
      width: 100%;
      padding: 14px;
      font-size: 16px;
      margin-top: 16px;
    }
    
    .auth-links {
      text-align: center;
      margin-top: 32px;
      color: var(--kp-on-surface-variant);
      font-size: 14px;
    }
    
    .auth-links a {
      font-weight: 600;
    }
  </style>
</head>

<body>
  <div class="kp-auth-wrapper">
    {{{body}}}
  </div>

  <!-- Toast Notification Container -->
  <div id="toast-container" class="toast-container"></div>

  <script>
    // Theme setup
    (function() {
      var savedTheme = localStorage.getItem('theme');
      var isDark = savedTheme === 'dark';
      if (isDark) document.body.classList.add('dark-theme');
    })();

    // Toast utility
    window.showToast = (message, type = 'info') => {
      const container = document.getElementById('toast-container');
      if (!container) return;
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      let icon = 'info';
      if (type === 'success') icon = 'check_circle';
      if (type === 'error') icon = 'error';
      toast.innerHTML = `<span class="material-symbols-outlined">${icon}</span> <span>${message}</span>`;
      container.appendChild(toast);
      toast.offsetHeight; // trigger reflow
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    };
  </script>
  {{{_scripts}}}
</body>

</html>
