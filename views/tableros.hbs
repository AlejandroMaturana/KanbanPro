<div class="dashboard-content" style="max-width: 1000px; margin: 0 auto;">
  <div class="dashboard-header" style="justify-content: space-between; align-items: center;">
    <div>
      <h1 style="font-size: 28px; margin-bottom: 8px;">Mis Tableros</h1>
      <p style="color: var(--kp-on-surface-variant); font-size: 15px;">Gestiona tus espacios de trabajo y proyectos.</p>
    </div>
    <button id="btnNuevoTablero" class="btn btn-primary">
      <span class="material-symbols-outlined">add_box</span>
      Nuevo Tablero
    </button>
  </div>

  <div class="tableros-list">
    {{#if data.tableros.length}}
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px;">
        {{#each data.tableros}}
          <div class="kp-card" style="display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s;">
            <div style="flex-grow: 1;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
                <h3 style="font-size: 18px; margin: 0;">{{this.titulo}}</h3>
                <span class="kp-priority-badge" style="{{#if this.esOwner}}background: var(--kp-primary-container); color: var(--kp-primary);{{else}}background: var(--kp-surface-hover); color: var(--kp-on-surface-variant);{{/if}}">
                  {{#if this.esOwner}}Propietario{{else}}Miembro{{/if}}
                </span>
              </div>
              
              {{#if this.descripcion}}
                <p style="color: var(--kp-on-surface-variant); font-size: 14px; line-height: 1.5; margin-bottom: 24px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                  {{this.descripcion}}
                </p>
              {{else}}
                <p style="color: var(--kp-on-surface-muted); font-size: 14px; font-style: italic; margin-bottom: 24px;">
                  Sin descripción
                </p>
              {{/if}}
            </div>

            <div style="display: flex; gap: 12px; border-top: 1px solid var(--kp-outline-variant); padding-top: 16px;">
              <a href="/dashboard?board={{this.id}}" class="btn btn-primary" style="flex: 1;">
                <span class="material-symbols-outlined" style="font-size: 20px;">visibility</span>
                Abrir
              </a>
              {{#if this.esOwner}}
                <button onclick="eliminarTablero('{{this.id}}')" class="btn btn-secondary" title="Eliminar tablero" style="color: var(--kp-error);">
                  <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                </button>
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div style="text-align: center; padding: 64px 24px; background: var(--kp-surface); border-radius: var(--kp-radius-xl); border: 1px dashed var(--kp-outline);">
        <span class="material-symbols-outlined" style="font-size: 48px; color: var(--kp-on-surface-muted); margin-bottom: 16px;">dashboard_customize</span>
        <h3 style="margin-bottom: 8px;">Aún no tienes tableros</h3>
        <p style="color: var(--kp-on-surface-variant); margin-bottom: 24px; max-width: 400px; margin-inline: auto;">
          Los tableros te ayudan a organizar tus tareas en listas. Crea tu primer tablero para comenzar.
        </p>
        <button onclick="document.getElementById('btnNuevoTablero').click()" class="btn btn-primary">
          Crea tu primer tablero
        </button>
      </div>
    {{/if}}
  </div>
</div>

<!-- Modal crear tablero -->
<div id="modalTablero" class="modal-overlay" role="dialog" aria-modal="true" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Nuevo Tablero</h2>
      <button id="btnCerrarModalTablero" class="close-modal">&times;</button>
    </div>

    <form id="formNuevoTablero">
      <div class="form-group">
        <label for="tituloTablero" class="form-label">Título *</label>
        <input
          type="text"
          id="tituloTablero"
          name="titulo"
          class="form-input"
          required
          placeholder="Ej: Proyecto Q4"
        />
      </div>

      <div class="form-group">
        <label for="descripcionTablero" class="form-label">Descripción</label>
        <textarea
          id="descripcionTablero"
          name="descripcion"
          class="form-input"
          rows="3"
          placeholder="Detalles sobre el objetivo del tablero..."
        ></textarea>
      </div>

      <div class="modal-actions">
        <button type="button" id="btnCancelarTablero" class="btn btn-secondary">Cancelar</button>
        <button type="submit" class="btn btn-primary">Crear Tablero</button>
      </div>
    </form>
  </div>
</div>

<script>
// --- Polyfills para customConfirm si no están cargados
if (typeof window.customConfirm !== 'function') {
  window.customConfirm = (message, title = 'Confirmar Acción') => {
    return new Promise((resolve) => {
      const overlay = document.getElementById('custom-confirm');
      if (!overlay) { resolve(confirm(message)); return; }
      document.getElementById('confirm-header').textContent = title;
      document.getElementById('confirm-body').textContent = message;
      overlay.classList.add('show');
      document.body.style.overflow = 'hidden';
      const cleanup = () => {
        overlay.classList.remove('show');
        document.body.style.overflow = 'auto';
        btnCancel.removeEventListener('click', onCancel);
        btnOk.removeEventListener('click', onOk);
      };
      const btnCancel = document.getElementById('confirm-cancel');
      const btnOk    = document.getElementById('confirm-ok');
      const onCancel = () => { cleanup(); resolve(false); };
      const onOk     = () => { cleanup(); resolve(true); };
      btnCancel.addEventListener('click', onCancel);
      btnOk.addEventListener('click', onOk);
    });
  };
}

document.addEventListener('DOMContentLoaded', () => {
  const modalTablero = document.getElementById('modalTablero');
  const btnNuevoTablero = document.getElementById('btnNuevoTablero');
  const btnCerrarModalTablero = document.getElementById('btnCerrarModalTablero');
  const btnCancelarTablero = document.getElementById('btnCancelarTablero');

  const abrirModal = () => {
    modalTablero.style.display = 'flex';
    // defer adding the show class to allow display:flex to apply first for animation
    setTimeout(() => modalTablero.classList.add('show'), 10);
    document.body.style.overflow = 'hidden';
  };

  const cerrarModal = () => {
    modalTablero.classList.remove('show');
    setTimeout(() => {
      modalTablero.style.display = 'none';
      document.body.style.overflow = 'auto';
    }, 200); // match transition duration
  };

  if (btnNuevoTablero) btnNuevoTablero.addEventListener('click', abrirModal);
  if (btnCerrarModalTablero) btnCerrarModalTablero.addEventListener('click', cerrarModal);
  if (btnCancelarTablero) btnCancelarTablero.addEventListener('click', cerrarModal);

  modalTablero.addEventListener('click', (e) => {
    if (e.target === modalTablero) cerrarModal();
  });

  const formNuevoTablero = document.getElementById('formNuevoTablero');
  if (formNuevoTablero) {
    formNuevoTablero.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = formNuevoTablero.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="material-symbols-outlined" style="animation: spin 1s linear infinite;">refresh</span> Creando...';
      }

      const titulo = document.getElementById('tituloTablero').value.trim();
      const descripcion = document.getElementById('descripcionTablero').value.trim();

      if (!titulo) {
        window.showToast('El título es obligatorio', 'error');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Crear Tablero';
        }
        return;
      }

      try {
        const response = await fetch('/api/tableros', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ titulo, descripcion })
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Error al crear tablero');
        }

        formNuevoTablero.reset();
        cerrarModal();
        window.showToast('Tablero creado exitosamente', 'success');
        setTimeout(() => window.location.reload(), 1000);
      } catch (error) {
        console.error('Error:', error);
        window.showToast(error.message, 'error');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Crear Tablero';
        }
      }
    });
  }

  window.eliminarTablero = async (tableroId) => {
    if (!tableroId) return;

    const isConfirmed = await window.customConfirm('¿Estás seguro de que deseas eliminar este tablero? Todas sus listas y tareas se perderán.', 'Eliminar Tablero');
    if (!isConfirmed) return;

    try {
      const response = await fetch(`/api/tableros/${tableroId}`, {
        method: 'DELETE'
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || 'Error al eliminar tablero');
      }

      window.showToast('Tablero eliminado', 'success');
      setTimeout(() => window.location.reload(), 1000);
    } catch (error) {
      console.error('Error:', error);
      window.showToast(error.message, 'error');
    }
  };
});
</script>

<style>
  @keyframes spin {
    100% { transform: rotate(360deg); }
  }
</style>
